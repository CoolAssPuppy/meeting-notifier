# Fastfile for MeetingNotifier
# Location: MeetingNotifier/fastlane/Fastfile
#
# This file contains all automation lanes for building and deploying MeetingNotifier
#
# Common lanes:
#   fastlane test              - Run all tests
#   fastlane beta              - Deploy to TestFlight
#   fastlane release           - Deploy to App Store
#   fastlane bump_patch        - Increment patch version (1.0.0 -> 1.0.1)
#   fastlane bump_minor        - Increment minor version (1.0.0 -> 1.1.0)
#   fastlane bump_major        - Increment major version (1.0.0 -> 2.0.0)

# Load environment variables from .env file
require 'dotenv'
env_file = File.expand_path('../.env', __dir__)
Dotenv.load(env_file) if File.exist?(env_file)

default_platform(:mac)

platform :mac do
  # ========================================
  # Configuration
  # ========================================

  SCHEME = "MeetingNotifier"
  XCODEPROJ = "MeetingNotifier.xcodeproj"
  APP_IDENTIFIER = "com.strategicnerds.meetingnotifier"

  # ========================================
  # Pre-flight Checks
  # ========================================

  desc "Verify environment and prerequisites"
  lane :prep do
    UI.message "🔍 Running pre-flight checks..."

    # Check required environment variables
    required_env_vars = [
      "FASTLANE_USER",
      "FASTLANE_TEAM_ID",
      "FASTLANE_ITC_TEAM_ID"
    ]

    missing_vars = required_env_vars.select { |var| ENV[var].nil? || ENV[var].empty? }

    if missing_vars.any?
      UI.user_error!("Missing required environment variables: #{missing_vars.join(', ')}")
      UI.message "Please set these in your .env file"
    end

    # Check for API key
    if ENV["APP_STORE_CONNECT_API_KEY_ID"] && !ENV["APP_STORE_CONNECT_API_KEY_ID"].empty?
      api_key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"] || "fastlane/app_store_connect_api_key.p8"
      # Make path relative to parent directory if it starts with fastlane/
      full_path = api_key_path.start_with?("fastlane/") ? File.expand_path("../#{api_key_path}", __dir__) : File.expand_path(api_key_path, __dir__)
      unless File.exist?(full_path)
        UI.user_error!("App Store Connect API key file not found at: #{api_key_path} (resolved to #{full_path})")
      end
      UI.success "✅ App Store Connect API key found at: #{api_key_path}"
    else
      UI.important "⚠️  No API key configured - will use Apple ID authentication (requires 2FA)"
    end

    # Verify Xcode project exists
    xcodeproj_path = File.expand_path("../#{XCODEPROJ}", __dir__)
    unless File.exist?(xcodeproj_path)
      UI.user_error!("Xcode project not found at: #{xcodeproj_path}")
    end

    UI.success "✅ All pre-flight checks passed!"
  end

  # ========================================
  # Testing
  # ========================================

  desc "Run all tests"
  lane :test do
    UI.message "🧪 Running tests..."

    scan(
      project: XCODEPROJ,
      scheme: SCHEME,
      clean: true,
      code_coverage: true,
      output_directory: "./fastlane/test_output",
      output_types: "html,junit",
      fail_build: true
    )

    UI.success "✅ All tests passed!"
  end

  # ========================================
  # Version Management
  # ========================================

  desc "Increment patch version (1.0.0 -> 1.0.1)"
  lane :bump_patch do
    current_version = sh("plutil -extract CFBundleShortVersionString raw ../MeetingNotifier/Info.plist").strip
    parts = current_version.split('.').map(&:to_i)
    new_version = "#{parts[0]}.#{parts[1]}.#{parts[2] + 1}"

    sh("plutil -replace CFBundleShortVersionString -string '#{new_version}' ../MeetingNotifier/Info.plist")
    UI.success "✅ Version bumped to #{new_version}"

    # Commit version bump
    git_commit(
      path: ["MeetingNotifier/Info.plist"],
      message: "Bump version to #{new_version}"
    )
  end

  desc "Increment minor version (1.0.0 -> 1.1.0)"
  lane :bump_minor do
    current_version = sh("plutil -extract CFBundleShortVersionString raw ../MeetingNotifier/Info.plist").strip
    parts = current_version.split('.').map(&:to_i)
    new_version = "#{parts[0]}.#{parts[1] + 1}.0"

    sh("plutil -replace CFBundleShortVersionString -string '#{new_version}' ../MeetingNotifier/Info.plist")
    UI.success "✅ Version bumped to #{new_version}"

    # Commit version bump
    git_commit(
      path: ["MeetingNotifier/Info.plist"],
      message: "Bump version to #{new_version}"
    )
  end

  desc "Increment major version (1.0.0 -> 2.0.0)"
  lane :bump_major do
    current_version = sh("plutil -extract CFBundleShortVersionString raw ../MeetingNotifier/Info.plist").strip
    parts = current_version.split('.').map(&:to_i)
    new_version = "#{parts[0] + 1}.0.0"

    sh("plutil -replace CFBundleShortVersionString -string '#{new_version}' ../MeetingNotifier/Info.plist")
    UI.success "✅ Version bumped to #{new_version}"

    # Commit version bump
    git_commit(
      path: ["MeetingNotifier/Info.plist"],
      message: "Bump version to #{new_version}"
    )
  end

  # ========================================
  # Build
  # ========================================

  desc "Build the app"
  lane :build do
    UI.message "🔨 Building MeetingNotifier..."

    # Get current build number and increment it
    build_number = sh("xcodebuild -project #{XCODEPROJ} -showBuildSettings | grep -w CURRENT_PROJECT_VERSION | awk '{print $3}'").strip.to_i
    new_build_number = build_number + 1

    # Update build number using PlistBuddy (works without agvtool)
    sh("plutil -replace CFBundleVersion -string '#{new_build_number}' ../MeetingNotifier/Info.plist")

    # Get version from plist
    version = sh("plutil -extract CFBundleShortVersionString raw ../MeetingNotifier/Info.plist").strip

    UI.message "Building version #{version} (#{new_build_number})"

    # Build and archive
    # For macOS App Store, we need to build with automatic signing
    # Xcode will create the provisioning profile automatically
    gym(
      scheme: SCHEME,
      output_directory: "./fastlane/builds",
      output_name: "MeetingNotifier",
      clean: true,
      export_method: "app-store",
      xcargs: "CODE_SIGN_STYLE=Automatic DEVELOPMENT_TEAM=955GSY56UT -allowProvisioningUpdates"
    )

    UI.success "✅ Build complete: #{version} (#{new_build_number})"
  end

  # ========================================
  # TestFlight Deployment
  # ========================================

  desc "Deploy to TestFlight"
  lane :beta do
    # Run pre-flight checks
    prep

    UI.message "🚀 Deploying to TestFlight..."

    # Optional: Run tests first (comment out if no tests)
    # test

    # Build the app
    build

    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: File.expand_path("../fastlane/app_store_connect_api_key.p8", __dir__)
    )

    # Get version info before upload
    version = sh("plutil -extract CFBundleShortVersionString raw ../MeetingNotifier/Info.plist").strip
    build_number = sh("plutil -extract CFBundleVersion raw ../MeetingNotifier/Info.plist").strip

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      skip_submission: true,  # Don't wait for processing
      distribute_external: false,  # Only internal testers initially
      changelog: ENV["TESTFLIGHT_CHANGELOG"] || "New build from CI/CD"
    )

    UI.success "✅ Successfully deployed #{version} (#{build_number}) to TestFlight!"
    UI.important "📱 Build will be available for testing after App Store processing (~10 minutes)"
    UI.important "📱 Check App Store Connect for build status"
  end

  # ========================================
  # App Store Release
  # ========================================

  desc "Deploy to App Store"
  lane :release do
    # Run pre-flight checks
    prep

    UI.message "🚀 Preparing App Store release..."

    # Safety confirmation
    if UI.confirm("Are you sure you want to deploy to production?")
      # Run tests
      test

      # Build the app
      build

      # Set up App Store Connect API key
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        key_filepath: File.expand_path("../fastlane/app_store_connect_api_key.p8", __dir__)
      )

      # Upload to App Store
      upload_to_app_store(
        api_key: api_key,
        app_identifier: APP_IDENTIFIER,
        skip_screenshots: true,
        skip_metadata: true,
        precheck_include_in_app_purchases: false,
        submit_for_review: false,  # Manual submission recommended
        automatic_release: false
      )

      version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
      build_number = get_build_number(xcodeproj: XCODEPROJ)

      UI.success "✅ Successfully uploaded #{version} (#{build_number}) to App Store!"
      UI.important "⚠️  Remember to manually submit for review in App Store Connect"

      # Create git tag
      add_git_tag(
        tag: "v#{version}",
        message: "Release #{version} (#{build_number})"
      )

      UI.success "📦 Git tag created: v#{version}"
    else
      UI.user_error!("Release cancelled by user")
    end
  end

  # ========================================
  # Metadata Management
  # ========================================

  desc "Download App Store metadata"
  lane :download_metadata do
    download_metadata(
      app_identifier: APP_IDENTIFIER,
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    UI.success "✅ Metadata downloaded to ./fastlane/metadata"
  end

  desc "Upload App Store metadata"
  lane :upload_metadata do
    upload_to_app_store(
      app_identifier: APP_IDENTIFIER,
      skip_binary_upload: true,
      skip_screenshots: false,
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    UI.success "✅ Metadata uploaded successfully"
  end

  # ========================================
  # Error Handling
  # ========================================

  error do |lane, exception|
    UI.error "❌ Lane '#{lane}' failed with error:"
    UI.error exception.message

    # Send notification (optional - configure Slack/Discord webhook)
    # slack(
    #   message: "Fastlane lane '#{lane}' failed!",
    #   success: false,
    #   slack_url: ENV["SLACK_WEBHOOK_URL"]
    # )
  end
end
