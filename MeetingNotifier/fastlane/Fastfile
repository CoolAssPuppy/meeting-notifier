# Fastfile for MeetingNotifier
# Location: MeetingNotifier/fastlane/Fastfile
#
# This file contains all automation lanes for building and deploying MeetingNotifier
#
# Common lanes:
#   fastlane test              - Run all tests
#   fastlane beta              - Deploy to TestFlight
#   fastlane release           - Deploy to App Store
#   fastlane bump_patch        - Increment patch version (1.0.0 -> 1.0.1)
#   fastlane bump_minor        - Increment minor version (1.0.0 -> 1.1.0)
#   fastlane bump_major        - Increment major version (1.0.0 -> 2.0.0)

# Import environment variables from .env file
import_from_git(
  url: "https://github.com/fastlane/fastlane",
  path: "fastlane/Fastfile"
) rescue nil

default_platform(:mac)

platform :mac do
  # ========================================
  # Configuration
  # ========================================

  SCHEME = "MeetingNotifier"
  XCODEPROJ = "./MeetingNotifier.xcodeproj"
  APP_IDENTIFIER = "com.strategicnerds.meetingnotifier"

  # ========================================
  # Pre-flight Checks
  # ========================================

  desc "Verify environment and prerequisites"
  lane :prep do
    UI.message "🔍 Running pre-flight checks..."

    # Check required environment variables
    required_env_vars = [
      "FASTLANE_USER",
      "FASTLANE_TEAM_ID",
      "FASTLANE_ITC_TEAM_ID"
    ]

    missing_vars = required_env_vars.select { |var| ENV[var].nil? || ENV[var].empty? }

    if missing_vars.any?
      UI.user_error!("Missing required environment variables: #{missing_vars.join(', ')}")
      UI.message "Please set these in your .env file"
    end

    # Check for API key
    if ENV["APP_STORE_CONNECT_API_KEY_ID"] && !ENV["APP_STORE_CONNECT_API_KEY_ID"].empty?
      api_key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"] || "fastlane/app_store_connect_api_key.p8"
      unless File.exist?(api_key_path)
        UI.user_error!("App Store Connect API key file not found at: #{api_key_path}")
      end
      UI.success "✅ App Store Connect API key found"
    else
      UI.important "⚠️  No API key configured - will use Apple ID authentication (requires 2FA)"
    end

    # Verify Xcode project exists
    unless File.exist?(XCODEPROJ)
      UI.user_error!("Xcode project not found at: #{XCODEPROJ}")
    end

    UI.success "✅ All pre-flight checks passed!"
  end

  # ========================================
  # Testing
  # ========================================

  desc "Run all tests"
  lane :test do
    UI.message "🧪 Running tests..."

    scan(
      project: XCODEPROJ,
      scheme: SCHEME,
      clean: true,
      code_coverage: true,
      output_directory: "./fastlane/test_output",
      output_types: "html,junit",
      fail_build: true
    )

    UI.success "✅ All tests passed!"
  end

  # ========================================
  # Version Management
  # ========================================

  desc "Increment patch version (1.0.0 -> 1.0.1)"
  lane :bump_patch do
    increment_version_number_in_xcodeproj(
      version_number: increment_version_number(
        bump_type: "patch",
        xcodeproj: XCODEPROJ
      ),
      xcodeproj: XCODEPROJ
    )

    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
    UI.success "✅ Version bumped to #{version}"

    # Commit version bump
    git_commit(
      path: [XCODEPROJ],
      message: "Bump version to #{version}"
    )
  end

  desc "Increment minor version (1.0.0 -> 1.1.0)"
  lane :bump_minor do
    increment_version_number_in_xcodeproj(
      version_number: increment_version_number(
        bump_type: "minor",
        xcodeproj: XCODEPROJ
      ),
      xcodeproj: XCODEPROJ
    )

    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
    UI.success "✅ Version bumped to #{version}"

    # Commit version bump
    git_commit(
      path: [XCODEPROJ],
      message: "Bump version to #{version}"
    )
  end

  desc "Increment major version (1.0.0 -> 2.0.0)"
  lane :bump_major do
    increment_version_number_in_xcodeproj(
      version_number: increment_version_number(
        bump_type: "major",
        xcodeproj: XCODEPROJ
      ),
      xcodeproj: XCODEPROJ
    )

    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
    UI.success "✅ Version bumped to #{version}"

    # Commit version bump
    git_commit(
      path: [XCODEPROJ],
      message: "Bump version to #{version}"
    )
  end

  # ========================================
  # Build
  # ========================================

  desc "Build the app"
  lane :build do
    UI.message "🔨 Building MeetingNotifier..."

    # Increment build number
    increment_build_number_in_xcodeproj(
      xcodeproj: XCODEPROJ
    )

    build_number = get_build_number(xcodeproj: XCODEPROJ)
    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)

    UI.message "Building version #{version} (#{build_number})"

    # Build and archive
    build_mac_app(
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./fastlane/builds",
      clean: true
    )

    UI.success "✅ Build complete: #{version} (#{build_number})"
  end

  # ========================================
  # TestFlight Deployment
  # ========================================

  desc "Deploy to TestFlight"
  lane :beta do
    # Run pre-flight checks
    prep

    UI.message "🚀 Deploying to TestFlight..."

    # Optional: Run tests first (comment out if no tests)
    # test

    # Build the app
    build

    # Upload to TestFlight
    upload_to_testflight(
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      distribute_external: false,  # Only internal testers initially
      changelog: ENV["TESTFLIGHT_CHANGELOG"] || "New build from CI/CD",
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
    build_number = get_build_number(xcodeproj: XCODEPROJ)

    UI.success "✅ Successfully deployed #{version} (#{build_number}) to TestFlight!"
    UI.important "📱 Build will be available for testing after App Store processing (~10 minutes)"
  end

  # ========================================
  # App Store Release
  # ========================================

  desc "Deploy to App Store"
  lane :release do
    # Run pre-flight checks
    prep

    UI.message "🚀 Preparing App Store release..."

    # Safety confirmation
    if UI.confirm("Are you sure you want to deploy to production?")
      # Run tests
      test

      # Build the app
      build

      # Upload to App Store
      upload_to_app_store(
        app_identifier: APP_IDENTIFIER,
        skip_screenshots: true,
        skip_metadata: true,
        precheck_include_in_app_purchases: false,
        submit_for_review: false,  # Manual submission recommended
        automatic_release: false,
        api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
      )

      version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
      build_number = get_build_number(xcodeproj: XCODEPROJ)

      UI.success "✅ Successfully uploaded #{version} (#{build_number}) to App Store!"
      UI.important "⚠️  Remember to manually submit for review in App Store Connect"

      # Create git tag
      add_git_tag(
        tag: "v#{version}",
        message: "Release #{version} (#{build_number})"
      )

      UI.success "📦 Git tag created: v#{version}"
    else
      UI.user_error!("Release cancelled by user")
    end
  end

  # ========================================
  # Metadata Management
  # ========================================

  desc "Download App Store metadata"
  lane :download_metadata do
    download_metadata(
      app_identifier: APP_IDENTIFIER,
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    UI.success "✅ Metadata downloaded to ./fastlane/metadata"
  end

  desc "Upload App Store metadata"
  lane :upload_metadata do
    upload_to_app_store(
      app_identifier: APP_IDENTIFIER,
      skip_binary_upload: true,
      skip_screenshots: false,
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    UI.success "✅ Metadata uploaded successfully"
  end

  # ========================================
  # Error Handling
  # ========================================

  error do |lane, exception|
    UI.error "❌ Lane '#{lane}' failed with error:"
    UI.error exception.message

    # Send notification (optional - configure Slack/Discord webhook)
    # slack(
    #   message: "Fastlane lane '#{lane}' failed!",
    #   success: false,
    #   slack_url: ENV["SLACK_WEBHOOK_URL"]
    # )
  end
end
