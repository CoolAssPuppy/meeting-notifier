# Gemfile for MeetingNotifier
# Location: MeetingNotifier/Gemfile
#
# This file specifies Ruby gem dependencies for Fastlane and automation tools
#
# To install:
#   bundle install
#
# To update:
#   bundle update

source "https://rubygems.org"

# Fastlane - App Store deployment automation
gem "fastlane", "~> 2.219"

# Ruby 3.4+ compatibility
gem "abbrev"
gem "ostruct"

# Environment variable management
gem "dotenv"

# Fastlane plugins
plugins_path = File.join(File.dirname(__FILE__), 'fastlane', 'Pluginfile')
eval_gemfile(plugins_path) if File.exist?(plugins_path)
